<Window x:Class="StreamCaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:StreamCaster.Converters"
        mc:Ignorable="d"
        Title="StreamCaster"
        Width="900"
        Height="820"
        MinWidth="820"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{Binding WindowBackgroundBrush}">
    <Window.Icon>
        <BitmapImage UriSource="pack://application:,,,/assets/StreamCaster.ico" />
    </Window.Icon>

    <Window.Resources>
        <converters:ProtocolDisplayConverter x:Key="ProtocolDisplay" />
        <converters:ProtocolBgColorConverter x:Key="ProtocolBgColor" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="Foreground" Value="{Binding SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
            <Setter Property="Background" Value="{Binding InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{Binding BorderBrushColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinHeight" Value="34" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
            <Setter Property="Background" Value="{Binding InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{Binding BorderBrushColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinHeight" Value="34" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{Binding AccentTextBrush}" />
            <Setter Property="Background" Value="{Binding AccentBrushColor}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="MinHeight" Value="34" />
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
            <Setter Property="Background" Value="{Binding SecondaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{Binding BorderBrushColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="MinHeight" Value="34" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Padding="16,14"
                CornerRadius="12"
                Background="{Binding HeaderBrush}"
                BorderBrush="{Binding BorderBrushColor}"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="38" Height="38" Margin="0,0,12,0" CornerRadius="10" ClipToBounds="True">
                    <Image Source="pack://application:,,,/assets/StreamCaster.png" Stretch="UniformToFill" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="20" FontWeight="Bold" Text="StreamCaster" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="{Binding SecondaryTextBrush}"
                               FontSize="12"
                               Text="{Binding FfmpegStatusText}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Stats Row -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,8,0" Padding="12,10" CornerRadius="10"
                    Background="{Binding PanelBrushColor}" BorderBrush="{Binding BorderBrushColor}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Foreground="{Binding SecondaryTextBrush}" FontSize="10" FontWeight="SemiBold" Text="STATUS" />
                    <TextBlock Margin="0,4,0,0" FontSize="16" FontWeight="Bold" Text="{Binding Stats.Status}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Margin="0,0,8,0" Padding="12,10" CornerRadius="10"
                    Background="{Binding PanelBrushColor}" BorderBrush="{Binding BorderBrushColor}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Foreground="{Binding SecondaryTextBrush}" FontSize="10" FontWeight="SemiBold" Text="BITRATE" />
                    <TextBlock Margin="0,4,0,0" FontSize="16" FontWeight="Bold" Text="{Binding Stats.Bitrate}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Margin="0,0,8,0" Padding="12,10" CornerRadius="10"
                    Background="{Binding PanelBrushColor}" BorderBrush="{Binding BorderBrushColor}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Foreground="{Binding SecondaryTextBrush}" FontSize="10" FontWeight="SemiBold" Text="BYTES SENT" />
                    <TextBlock Margin="0,4,0,0" FontSize="16" FontWeight="Bold" Text="{Binding Stats.BytesSent}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Margin="0,0,8,0" Padding="12,10" CornerRadius="10"
                    Background="{Binding PanelBrushColor}" BorderBrush="{Binding BorderBrushColor}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Foreground="{Binding SecondaryTextBrush}" FontSize="10" FontWeight="SemiBold" Text="HTTP CLIENTS" />
                    <TextBlock Margin="0,4,0,0" FontSize="16" FontWeight="Bold" Text="{Binding HttpClientSummary}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Padding="12,10" CornerRadius="10"
                    Background="{Binding PanelBrushColor}" BorderBrush="{Binding BorderBrushColor}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Foreground="{Binding SecondaryTextBrush}" FontSize="10" FontWeight="SemiBold" Text="CURRENT TARGET" />
                    <TextBlock Margin="0,4,0,0" FontSize="12" FontWeight="Bold"
                               Text="{Binding OutputPreview}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Control Panel -->
        <Border Grid.Row="2"
                Padding="16"
                CornerRadius="12"
                Background="{Binding PanelBrushColor}"
                BorderBrush="{Binding BorderBrushColor}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Control" />

                <!-- Input -->
                <TextBlock Margin="0,12,0,5" Style="{StaticResource FieldLabelStyle}" Text="INPUT FILE" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding InputPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1" Margin="8,0,0,0" Content="Browse"
                            Style="{StaticResource SecondaryButtonStyle}" Click="BrowseInput_Click" />
                </Grid>

                <!-- NIC + Protocol -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.4*" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="NETWORK INTERFACE" />
                        <ComboBox ItemsSource="{Binding NetworkInterfaces}" SelectedItem="{Binding SelectedNetworkInterface}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="PROTOCOL" />
                        <ComboBox ItemsSource="{Binding Protocols}" SelectedItem="{Binding SelectedProtocol}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="5" Padding="10,3"
                                            Background="{Binding Converter={StaticResource ProtocolBgColor}}"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Converter={StaticResource ProtocolDisplay}}"
                                                   Foreground="White" FontWeight="Bold" FontSize="12" />
                                    </Border>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Target Address -->
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="TARGET ADDRESS  (예: 172.16.59.6:7001/live/live)" />
                    <TextBox Text="{Binding TargetAddress, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- Options Row -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="LOOP" />
                        <CheckBox Content="Enable" IsChecked="{Binding LoopEnabled}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="PKT SIZE" />
                        <TextBox HorizontalContentAlignment="Center"
                                 Text="{Binding PacketSize, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="TTL" />
                        <TextBox HorizontalContentAlignment="Center"
                                 Text="{Binding Ttl, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Margin="0,0,8,0" Content="Start"
                                Style="{StaticResource PrimaryButtonStyle}" Click="Start_Click" />
                        <Button Content="Stop"
                                Style="{StaticResource SecondaryButtonStyle}" Click="Stop_Click" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Log Panel -->
        <Border Grid.Row="3"
                Margin="0,10,0,0"
                Padding="14"
                CornerRadius="12"
                Background="{Binding PanelAltBrushColor}"
                BorderBrush="{Binding BorderBrushColor}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Status Log" />
                    <TextBlock Grid.Column="1"
                               Margin="12,2,0,0"
                               Foreground="{Binding SecondaryTextBrush}"
                               FontSize="11"
                               Text="{Binding StatusSummary}"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Margin="8,0,8,0"
                                Content="Save Log"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="SaveLog_Click" />
                        <Button Content="Clear Log"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ClearLog_Click" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Foreground="{Binding SecondaryTextBrush}"
                               FontSize="11"
                               Text="{Binding LogFileStatus}" />
                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding LogFilterText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="로그 필터"
                                 />
                        <Button Grid.Column="1" Margin="8,0,0,0"
                                Content="All"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ShowAllLogs_Click" />
                        <Button Grid.Column="2" Margin="8,0,0,0"
                                Content="Client"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ShowClientLogs_Click" />
                        <Button Grid.Column="3" Margin="8,0,0,0"
                                Content="Error"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ShowErrorLogs_Click" />
                    </Grid>
                    <TextBox x:Name="LogTextBox"
                             Grid.Row="2"
                             Margin="0,6,0,0"
                             IsReadOnly="True"
                             Text="{Binding LogText}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             Background="{Binding CodeBackgroundBrush}"
                             BorderBrush="{Binding BorderBrushColor}"
                             Foreground="{Binding PrimaryTextBrush}"
                             FontFamily="Consolas"
                             FontSize="12" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
